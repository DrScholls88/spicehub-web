    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dexie": "^4.3.0",
    "dexie-observable": "^4.0.1-beta.13",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.41.0",
    "parse-ingredient": "^2.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
