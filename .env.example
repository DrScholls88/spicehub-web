# SpiceHub environment variables — copy to .env and fill in values

# Unified Import Engine (v2)
VITE_USE_V2_IMPORT=true
VITE_API_BASE=https://your-render-service.onrender.com

# Backend (set in Render dashboard, not here)
ENABLE_V2_IMPORT=true
IG_COOKIES_JSON_B64=<base64 of cookies.json>
GEMINI_API_KEY=<your key>

# Photo / document import — tiered vision pipeline (all optional, all free tier)
# Tier 1: Gemini vision (uses VITE_GOOGLE_AI_KEY). Override the model if needed:
# VITE_GEMINI_VISION_MODEL=gemini-2.0-flash-lite
# Tier 2: Mistral La Plateforme "Experiment" tier (free) — https://console.mistral.ai
# VITE_MISTRAL_API_KEY=<your key>
# VITE_MISTRAL_MODEL=pixtral-12b-latest
# Tier 3: on-device Tesseract OCR — no key, always available (offline fallback)
